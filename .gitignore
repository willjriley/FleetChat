# FleetChat -- never commit local state or real secrets.

# ephemeral board state: the message log, run logs, and the crew PID registry
data/

# your real config (may carry a token) -- only config.example.json is tracked
config.json
.env

# your real fleet + personas -- may name real people/infra, so NEVER commit them.
# Only fleet.local.example.json is tracked. Resolver: run.py -> fleet_file()/persona_base_dirs().
fleet.local.json
personas.local/

# Python
__pycache__/
*.pyc

# Go daemon build output/logs -- daemon/*.go is the source of truth, never the binary.
#
# Deliberately NOT pinned to a single filename. The module is `daemon-skeleton`, so
# `go build` emits daemon-skeleton.exe on Windows and an EXTENSIONLESS
# daemon-skeleton on linux/darwin. The previous `daemon/daemon.exe` rule named a
# file the module has never produced, so both real artifacts (~20MB together) sat
# untracked-but-unignored, one `git add -A` away from a public repo.
#
# That is not just bloat: these binaries embed the builder's absolute source path
# (verified -- `C:/Users/<name>` is greppable in both), so committing one leaks a
# box-local path into public history. `*.test` catches `go test -c` output on POSIX;
# `*.exe` already covers its Windows counterpart.
daemon/*.exe
daemon/daemon-skeleton
daemon/*.test
daemon/*.log

# local-only working docs (audit briefs, notes, scratch) -- never committed
local/

# relay-test scratch
.fleet-relay/

# stray local build artifacts
daemon/daemon-skeleton
daemon/daemon-skeleton.exe
